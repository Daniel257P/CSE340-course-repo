<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <nav>
        <ul>
            <li><a href="/" class="<%= currentPath === '/' ? 'active' : '' %>" <%= currentPath === '/' ? 'aria-current="page"' : '' %>>Home</a></li>
            <li><a href="/organizations" class="<%= currentPath.startsWith('/organization') ? 'active' : '' %>" <%= currentPath.startsWith('/organization') ? 'aria-current="page"' : '' %>>Organizations</a></li>
            <li><a href="/projects" class="<%= currentPath.startsWith('/project') ? 'active' : '' %>" <%= currentPath.startsWith('/project') ? 'aria-current="page"' : '' %>>Projects</a></li>
            <li><a href="/categories" class="<%= currentPath.startsWith('/categories') ? 'active' : '' %>" <%= currentPath.startsWith('/categories') ? 'aria-current="page"' : '' %>>Categories</a></li>
        </ul>
    </nav>
    <div class="flash-container">
        <% const messages = flash(); %>
        <% Object.keys(messages).forEach(type => { %>
            <% if (messages[type].length > 0) { %>
                <% messages[type].forEach(msg => { %>
                    <div class="alert <%= type %>"><%= msg %></div>
                <% }); %>
            <% } %>
        <% }); %>
    </div>